{
  "name": "aura-theme-2026",
  "displayName": "Aura Theme 2026",
  "description": "A beautiful dark theme for Visual Studio Code, remapped in the 2026 style",
  "version": "2.1.2",
  "scripts": {
    "package:vsix": "npx @vscode/vsce package",
    "publish": "vsce publish"
  },
  "publisher": "yukiumi13",
  "author": {
    "name": "Dalton Menezes",
    "email": "daltonmenezes@outlook.com",
    "url": "https://daltonmenezes.github.io"
  },
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#15141b",
    "theme": "dark"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.47.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "aura-theme",
    "color-theme"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Aura 2026 Dark (Soft Text)",
        "uiTheme": "vs-dark",
        "path": "./themes/aura-dark-soft-text-color-theme.json"
      },
      {
        "label": "Aura 2026 Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/aura-dark-color-theme.json"
      },
      {
        "label": "Aura 2026 Soft Dark (Soft Text)",
        "uiTheme": "vs-dark",
        "path": "./themes/aura-soft-dark-soft-text-color-theme.json"
      },
      {
        "label": "Aura 2026 Soft Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/aura-soft-dark-color-theme.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yukiumi13/aura-theme-2026.git"
  },
  "bugs": {
    "url": "https://github.com/yukiumi13/aura-theme-2026/issues"
  }
}