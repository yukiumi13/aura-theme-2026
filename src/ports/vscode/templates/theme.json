  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "{{ syntaxComment }}"
      }
    },
    {
      "scope": [
        "constant.other.placeholder",
        "constant.character"
      ],
      "settings": {
        "foreground": "{{ syntaxProperty }}"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "entity",
        "support.constant",
        "support.variable",
        "meta.module-reference"
      ],
      "settings": {
        "foreground": "{{ syntaxConstant }}"
      }
    },
    {
      "scope": [
        "entity.name",
        "meta.export.default",
        "meta.definition.variable",
        "markup.changed",
        "entity.name.section.markdown",
        "support.function"
      ],
      "settings": {
        "foreground": "{{ syntaxFunction }}"
      }
    },
    {
      "scope": [
        "variable.parameter.function",
        "variable.parameter",
        "meta.function-call.arguments.python variable.parameter"
      ],
      "settings": {
        "foreground": "{{ syntaxParameter }}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "meta.block",
        "meta.tag.attributes",
        "meta.object.member",
        "meta.embedded.expression",
        "variable",
        "variable.other",
        "markup.list",
        "meta.class",
        "meta.method.declaration",
        "parameter.variable.function.elixir",
        "punctuation.definition.tag",
        "punctuation.section.embedded",
        "punctuation.terminator.dart",
        "punctuation.dot.dart"
      ],
      "settings": {
        "foreground": "{{ syntaxVariable }}"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.elixir",
        "entity.name.function-call.elixir",
        "meta.function-call.generic.python"
      ],
      "settings": {
        "foreground": "{{ syntaxFunction }}"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component",
        "support.class.component.tsx",
        "support.class.component.open.jsx",
        "support.class.component.close.jsx",
        "markup.inserted",
        "support.type.builtin.graphql",
        "entity.other.attribute-name.id.css",
        "JSXNested"
      ],
      "settings": {
        "foreground": "{{ syntaxTag }}"
      }
    },
    {
      "scope": [
        "keyword.control.import.python",
        "keyword.control.from.python",
        "keyword.control.as.python",
        "storage.modifier.import.python"
      ],
      "settings": {
        "foreground": "{{ syntaxKeyword }}"
      }
    },
    {
      "scope": [
        "meta.import.python support.type",
        "meta.import.python support.class",
        "meta.import.python entity.name.module.python",
        "meta.import.python meta.path.python",
        "meta.import.python meta.import-name.python"
      ],
      "settings": {
        "foreground": "{{ syntaxNamespace }}"
      }
    },
    {
      "scope": [
        "meta.import.python punctuation.separator.period.python",
        "meta.import.python punctuation.separator.comma.python"
      ],
      "settings": {
        "foreground": "{{ accent10 }}"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "keyword.control.flow",
        "storage.modifier",
        "keyword.operator",
        "markup.heading",
        "markup.underline.link",
        "variable.other.env",
        "constant.length.units.css",
        "constant.percentage.units.css"
      ],
      "settings": {
        "foreground": "{{ syntaxKeyword }}"
      }
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "{{ accent9 }}"
      }
    },
    {
      "scope": [
        "string",
        "string punctuation.section.embedded source",
        "source.env",
        "variable.other.quoted.double",
        "markup.inline.raw.string.markdown",
        "markup.raw"
      ],
      "settings": {
        "foreground": "{{ syntaxString }}"
      }
    },
    {
      "scope": [
        "support",
        "meta.property-name",
        "string variable",
        "support.class.builtin",
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.quasi.element.begin",
        "punctuation.quasi.element.end",
        "entity.other.inherited-class",
        "variable.other.constant.elixir",
        "support.class.dart"
      ],
      "settings": {
        "foreground": "{{ syntaxType }}"
      }
    },
    {
      "scope": [
        "string.unquoted",
        "punctuation.separator",
        "entity.other.attribute-name",
        "meta.object-literal.key",
        "variable.object.property",
        "variable.other.property",
        "variable.other.object.property",
        "variable.other.constant.property",
        "meta.type.annotation",
        "support.type.property-name.css",
        "support.type.vendored",
        "constant.language.symbol.elixir",
        "variable.graphql",
        "meta.attribute.python",
        "source.dart",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "{{ syntaxProperty }}"
      }
    },
    {
      "scope": [
        "invalid.broken",
        "invalid.deprecated",
        "invalid.illegal",
        "invalid.unimplemented",
        "invalid",
        "message.error",
        "markup.deleted"
      ],
      "settings": {
        "foreground": "{{ accent5 }}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "foreground": "{{ accent7 }}",
        "background": "{{ accent5 }}",
        "fontStyle": "italic underline"
      }
    },
    {
      "scope": [
        "source.regexp",
        "string.regexp",
        "constant.other.reference.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "{{ syntaxRegexp }}"
      }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "{{ syntaxStringEscape }}"
      }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": {
        "foreground": "{{ syntaxStringEscape }}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "{{ syntaxProperty }}"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "{{ syntaxTitle }}"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "{{ syntaxTitle }}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "{{ syntaxString }}"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "{{ accent7 }}",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "{{ accent7 }}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "{{ syntaxLink }}"
      }
    },
    {
      "scope": [
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "{{ accent5 }}"
      }
    },
    {
      "scope": "punctuation.section.embedded",
      "settings": {
        "foreground": "{{ syntaxKeyword }}"
      }
    },
    {
      "scope": [
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "{{ ansiBrightGreen }}"
      }
    },
    {
      "scope": "punctuation.definition.changed",
      "settings": {
        "foreground": "{{ uiStatusModified }}"
      }
    },
    {
      "scope": [
        "markup.ignored",
        "markup.untracked"
      ],
      "settings": {
        "foreground": "{{ accent12 }}"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "foreground": "{{ accent1 }}",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator",
        "meta.output",
        "support.constant.property-value.css",
        "variable.parameter.keyframe-list.css",
        "source.css",
        "support.constant.font-name",
        "support.constant.vendored.property-value"
      ],
      "settings": {
        "foreground": "{{ syntaxType }}"
      }
    },
    {
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "settings": {
        "foreground": "{{ accent8 }}"
      }
    },
    {
      "scope": "brackethighlighter.unmatched",
      "settings": {
        "foreground": "{{ accent5 }}"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "{{ syntaxType }}"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "{{ uiStatusWarning }}"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "{{ accent5 }}"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "{{ syntaxKeyword }}"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": "{{ syntaxComment }}",
    "string": "{{ syntaxString }}",
    "regexp": "{{ syntaxRegexp }}",
    "regexp.escape": {
      "foreground": "{{ syntaxStringEscape }}",
      "fontStyle": "bold"
    },
    "number": "{{ syntaxNumber }}",
    "boolean": "{{ syntaxBoolean }}",
    "enumMember": "{{ syntaxEnumMember }}",
    "function": "{{ syntaxFunction }}",
    "method": "{{ syntaxFunction }}",
    "macro": "{{ syntaxMacro }}",
    "parameter": {
      "foreground": "{{ syntaxParameter }}",
      "fontStyle": "italic"
    },
    "variable": "{{ syntaxVariable }}",
    "variable.defaultLibrary": "{{ syntaxVariableSpecial }}",
    "variable.readonly": "{{ syntaxVariableSpecial }}",
    "property": "{{ syntaxProperty }}",
    "property.readonly": "{{ syntaxVariableSpecial }}",
    "class": "{{ syntaxClass }}",
    "interface": {
      "foreground": "{{ syntaxType }}",
      "fontStyle": "italic"
    },
    "enum": "{{ syntaxEnum }}",
    "type": "{{ syntaxType }}",
    "type.defaultLibrary": "{{ syntaxType }}",
    "typeParameter": {
      "foreground": "{{ syntaxType }}",
      "fontStyle": "italic"
    },
    "namespace": "{{ syntaxNamespace }}",
    "keyword": "{{ syntaxKeyword }}",
    "modifier": "{{ syntaxKeyword }}",
    "operator": "{{ syntaxOperator }}",
    "decorator": "{{ syntaxDecorator }}",
    "label": "{{ syntaxLabel }}"
  },
  "semanticHighlighting": true
}
